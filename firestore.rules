rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives & Auth ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'lm656508@gmail.com');
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'lm656508@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'username', 'email']) &&
             data.displayName is string && data.displayName.size() >= 2 && data.displayName.size() <= 50 &&
             data.username is string && data.username.size() >= 2 && data.username.size() <= 15 && data.username.matches('^[a-z0-9_]+$') &&
             data.email is string && data.email.size() <= 100 &&
             (!data.hasAll(['isBanned']) || data.isBanned is bool) &&
             (!data.hasAll(['isMuted']) || data.isMuted is bool) &&
             (!data.hasAll(['isVip']) || data.isVip is bool) &&
             (!data.hasAll(['membership']) || data.membership in ['none', 'premium', 'influencer', 'famous']) &&
             (!data.hasAll(['createdAt']) || data.createdAt is string); // Or timestamp
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'uid', 'displayName', 'timestamp', 'room']) &&
             data.text is string && data.text.size() <= 1000 &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 50 &&
             data.room is string && data.room.size() <= 100 &&
             data.timestamp == request.time;
    }

    // --- Match Blocks ---

    // 1. Users Collection
    match /users/{userId} {
      // Identity Protection: PII (email) is present, but reading profile is needed for chat.
      // We restrict list to prevent scraping.
      allow get: if isSignedIn();
      allow list: if isSignedIn() && userId == request.auth.uid; // Secured list query

      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                       // Standard users cannot self-assign VIP/Staff roles
                       incoming().isVip == false && 
                       incoming().membership == 'none' &&
                       incoming().isBanned == false;

      allow update: if (
        (isOwner(userId) && isValidUser(incoming()) && (
          // Action: Profile Update (Owner can ONLY change non-auth fields)
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'username', 'photoURL', 'emailVerified']) &&
          (!incoming().hasAny(['isVip']) || incoming().isVip == existing().isVip) &&
          (!incoming().hasAny(['membership']) || incoming().membership == existing().membership)
        )) ||
        (isAdmin() && isValidUser(incoming()) && (
          // Action: Admin Modification
          incoming().diff(existing()).affectedKeys().hasOnly(['isBanned', 'isMuted', 'isVip', 'membership', 'displayName']) &&
          isValidId(userId)
        ))
      );
    }

    // 2. Rooms Collection (Static metadata)
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      // Messages Subcollection
      match /messages/{messageId} {
        allow list: if isSignedIn() && isEmailVerified(); // Forced secure query
        allow get: if isSignedIn();
        
        allow create: if isEmailVerified() && 
                        isValidId(roomId) && 
                        isValidMessage(incoming());
        
        allow update, delete: if isSignedIn() && (
          isOwner(resource.data.uid) || isAdmin()
        );
      }
    }

    // 3. System Collection
    match /system/health {
      allow read: if true; // Public health check
      allow write: if false; // System only
    }

    // 4. Admins Collection (Explicit Role Store)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Provisioned via console/CLI
    }
  }
}
